{
  "globals": {
    "module": true,
    "ref": true,
    "reactive": true,
    "defineAsyncComponent": true,
    "useRouter": true
  },
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:vue/vue3-essential",
    "plugin:@typescript-eslint/recommended"
  ],
  "overrides": [],
  "parser": "vue-eslint-parser",
  "parserOptions": {
    "parser": "@typescript-eslint/parser",
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": [
    "vue",
    "@typescript-eslint"
  ],
  "rules": {
    "quotes": [
      "error",
      "single"
    ],
    "vue/multi-word-component-names": [
      "error",
      {
        "ignores": [
          "Books",
          "Chapters",
          "Content"
        ]
      }
    ]
  }
}